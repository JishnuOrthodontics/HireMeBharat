# Reference: names to create under GitHub → Settings → Secrets and variables → Actions.
# Do not commit real values. Copy each NAME into the UI and paste the secret value.

# GCP VM (after fresh VM + static IP + deploy key)
GCP_VM_IP=
GCP_VM_USERNAME=
GCP_VM_SSH_KEY=
# Optional if private key is passphrase-protected:
GCP_VM_SSH_KEY_PASSPHRASE=

# Database & Firebase (backend)
MONGODB_URI=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Cloudflare — Pages deploy (deploy-frontend.yml)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional — CI post-deploy check (deploy-backend.yml): curl ${PUBLIC_API_URL}/api/health
# Prefer Repository variables → PUBLIC_API_URL; secret name PUBLIC_API_URL also supported.
PUBLIC_API_URL=

# Frontend build (Vite); VITE_API_URL must match public API hostname
VITE_API_URL=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional — override docker registry htpasswd defaults in full-stack deploy
# REGISTRY_USER=
# REGISTRY_PASSWORD=

