{
  "name": "hiremebharat",
  "version": "0.1.0",
  "private": true,
  "description": "HireMeBharat — Premium Concierge Recruitment Platform",
  "workspaces": [
    "packages/*",
    "apps/web",
    "apps/api-gateway",
    "apps/api-auth",
    "apps/api-employee",
    "apps/api-employer",
    "apps/api-admin"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:gateway": "npm run dev --workspace=apps/api-gateway",
    "dev:auth": "npm run dev --workspace=apps/api-auth",
    "dev:employee": "npm run dev --workspace=apps/api-employee",
    "dev:employer": "npm run dev --workspace=apps/api-employer",
    "dev:admin": "npm run dev --workspace=apps/api-admin",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:employee\" \"npm run dev:employer\" \"npm run dev:admin\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}

